{
  "manifest_version": 3,
  "name": "Spam Detector",
  "version": "1.0",
  "description": "Detect spam in selected text",
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.jpeg",
      "48": "icon48.jpeg",
      "32": "icon32.jpeg"
    }
  },
  "icons": {
    "16": "icon16.jpeg",
    "48": "icon48.jpeg",
    "32": "icon32.jpeg"
  }
}